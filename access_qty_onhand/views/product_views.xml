<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="product_template_update_quantity" model="ir.ui.view">
        <field name="name">product.template.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="stock.product_template_form_view_procurement_button"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_update_quantity_on_hand']" position="attributes">
                <attribute name="groups">access_qty_onhand.group_access_on_hand_qty</attribute>
            </xpath>
             <xpath expr="//button[@name='%(stock.action_product_replenish)d']" position="attributes">
                <attribute name="groups">access_qty_onhand.group_access_on_hand_qty</attribute>
            </xpath>
            <xpath expr="//div[@name='button_box']//button[@name='action_update_quantity_on_hand']" position="attributes">
                <attribute name="groups">access_qty_onhand.group_access_on_hand_qty</attribute>
            </xpath>
            <xpath expr="//button[@name='action_product_tmpl_forecast_report']" position="attributes">
                <attribute name="groups">access_qty_onhand.group_access_forecast_qty</attribute>
            </xpath>
        </field>
    </record>

    <record id="product_product_view_form_easy_inherit_stock" model="ir.ui.view">
        <field name="name">product.product.form</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="stock.product_product_view_form_easy_inherit_stock"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_update_quantity_on_hand']" position="attributes">
                <attribute name="groups">access_qty_onhand.group_access_on_hand_qty</attribute>
            </xpath>
            <xpath expr="//button[@name='%(stock.action_product_replenish)d']" position="attributes">
                <attribute name="groups">access_qty_onhand.group_access_on_hand_qty</attribute>
            </xpath>
        </field>
    </record>
    <record id="product_form_view_procurement_button" model="ir.ui.view">
        <field name="name">product.product.form</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="stock.product_form_view_procurement_button"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_update_quantity_on_hand']" position="attributes">
                <attribute name="groups">access_qty_onhand.group_access_on_hand_qty</attribute>
            </xpath>
            <xpath expr="//button[@name='%(stock.action_product_replenish)d']" position="attributes">
                <attribute name="groups">access_qty_onhand.group_access_on_hand_qty</attribute>
            </xpath>
        </field>
    </record>


    <record model="ir.ui.menu" id="stock.menu_action_inventory_tree">
        <field name="groups_id" eval="[(6,0,[ref('access_qty_onhand.group_access_inventory_adjustment')])]"/>
    </record>

    <record model="ir.ui.menu" id="stock.menu_stock_scrap">
        <field name="groups_id" eval="[(6,0,[ref('access_qty_onhand.group_access_inventory_adjustment')])]"/>
    </record>


</odoo>


