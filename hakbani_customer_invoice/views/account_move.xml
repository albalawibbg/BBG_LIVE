<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="account_move_form_view_inherit" model="ir.ui.view">
        <field name="name">account_move_form_view_inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_reference']" position="after">
                <field name="invoice_payment_type"/>
            </xpath>
            <xpath expr="//button[@name='action_register_payment']" position="attributes">
                <attribute name="groups">hakbani_customer_invoice.group_register_payment</attribute>
            </xpath>
        </field>
    </record>
    <record id="account_move_tree_view_inherit" model="ir.ui.view">
        <field name="name">account_move_tree_view_inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_register_payment']" position="attributes">
                <attribute name="groups">hakbani_customer_invoice.group_register_payment</attribute>
            </xpath>
        </field>
    </record>

</odoo>


