<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="base_document_layout_wizard_inherit" model="ir.ui.view">
        <field name="name">base.document.layout.wizard.inherit</field>
        <field name="model">base.document.layout</field>
        <field name="inherit_id" ref="web.view_base_document_layout"/>
        <field name="arch" type="xml">
            <field name="paperformat_id" position="after">
                <field name="custom_header"/>
                <field name="img_custom_header" invisible="not custom_header"/>
                <field name="custom_footer"/>
                <field name="img_custom_footer" invisible="not custom_footer"/>
            </field>
        </field>
    </record>
</odoo>
